# Plasma Testnet RPC
PLASMA_TESTNET_RPC=https://your-plasma-testnet-rpc

# Danny = the "Plasma user" receiving funds via stealth address
# This simulates the Privy EOA
DANNY_PRIVATE_KEY=0x...

# Sender = external party (Bridge, Binance, another user, etc.)
# Needs a separate key — can be any funded testnet account
SENDER_PRIVATE_KEY=0x...

# Both accounts need testnet XPL for gas
# Danny's account also needs XPL to register the meta-address
